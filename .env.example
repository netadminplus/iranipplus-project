# ─────────────────────────────────────────────────────
# Iranipplus.com — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# ── Site URLs ────────────────────────────────────────
SITE_URL=https://iranipplus.com
CMS_PUBLIC_URL=https://admin.iranipplus.com

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=iranipplus
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=iranipplus_db
DATABASE_URI=postgresql://iranipplus:CHANGE_ME_strong_password_here@db:5432/iranipplus_db

# ── Payload CMS ──────────────────────────────────────
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_at_least_32_chars_random_string

# ── Node ─────────────────────────────────────────────
NODE_ENV=production
